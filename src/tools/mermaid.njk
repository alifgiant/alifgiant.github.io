---
layout: layouts/base.njk
title: Mermaid Diagram Generator
description: Generate Mermaid diagrams from code with zoom, pan, cheatsheet, and image export.
permalink: /tools/mermaid/
---

<script src="https://cdn.jsdelivr.net/npm/mermaid@11.14.0/dist/mermaid.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/svg-pan-zoom@3.6.2/dist/svg-pan-zoom.min.js"></script>

<div class="w-full max-w-7xl flex flex-col gap-12" x-data="mermaidTool()">
    {# Header #}
    {% set tool = {} %}
    {% for item in site.pages.tools.list %}
        {% if item.url == "/tools/mermaid/" %}
            {% set tool = item %}
        {% endif %}
    {% endfor %}
    {% set cat = site.pages.tools.categories[tool.tag] %}

    <div class="flex flex-col gap-4 text-center items-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border {{ cat.color }}">
            <span class="material-symbols-outlined text-sm">{{ cat.icon }}</span>
            {{ tool.tag }}
        </div>
        <div class="w-16 h-16 rounded-2xl {{ cat.lightColor }} flex items-center justify-center mb-2">
            <span class="material-symbols-outlined text-4xl">{{ tool.icon }}</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-text-main font-display">
            {{ tool.title }}
        </h1>
        <p class="text-lg text-text-muted max-w-3xl leading-relaxed">
            {{ tool.description }}
        </p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8 items-start">
        {# Main Canvas + Editor #}
        <div class="xl:col-span-8 flex flex-col gap-6">
            <div class="bg-white/80 backdrop-blur-md border border-white rounded-[2.5rem] p-6 md:p-8 shadow-xl shadow-primary/10 flex flex-col gap-6">
                <div class="flex flex-wrap gap-3 items-center justify-between">
                    <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-text-muted">Mermaid Code</label>
                    <div class="flex flex-wrap gap-2">
                        <button @click="renderDiagram()" class="px-4 py-2 rounded-xl bg-text-main text-white font-bold text-xs uppercase tracking-wider hover:bg-primary transition-colors flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">play_arrow</span>
                            Render
                        </button>
                        <button @click="resetSample()" class="px-4 py-2 rounded-xl bg-white border border-stone-200 text-text-muted font-bold text-xs uppercase tracking-wider hover:border-primary hover:text-primary transition-colors flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">restart_alt</span>
                            Reset
                        </button>
                        <button @click="clearCode()" class="px-4 py-2 rounded-xl bg-white border border-stone-200 text-text-muted font-bold text-xs uppercase tracking-wider hover:border-rose-300 hover:text-rose-600 transition-colors flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">delete</span>
                            Clear
                        </button>
                    </div>
                </div>

                <div class="relative w-full bg-stone-50 border-2 border-stone-100 rounded-2xl shadow-inner overflow-hidden" style="min-height: 320px; height: 320px; resize: vertical;">
                    <div x-ref="highlightLayer" x-html="highlightedDiagramCode"
                         class="mermaid-editor-code absolute inset-0 px-5 py-4 text-sm pointer-events-none overflow-auto text-text-main"></div>

                    <textarea x-ref="codeInput" x-model="diagramCode" @scroll="syncEditorScroll()" spellcheck="false" placeholder="flowchart TD\nA[Start] --> B{Condition}\nB -->|Yes| C[Do Something]\nB -->|No| D[Do Something Else]"
                        class="mermaid-editor-code mermaid-editor-input relative z-10 block w-full h-full px-5 py-4 bg-transparent text-transparent caret-text-main placeholder:text-stone-400 focus:outline-none focus:bg-white/20 transition-all resize-none"></textarea>
                </div>

                <div x-show="error" class="p-4 bg-rose-50 text-rose-700 border border-rose-100 rounded-2xl text-xs flex items-start gap-3" x-cloak>
                    <span class="material-symbols-outlined text-lg">error</span>
                    <div class="flex flex-col gap-1">
                        <span class="font-bold uppercase tracking-wider">Render Error</span>
                        <span x-text="error"></span>
                    </div>
                </div>
            </div>

            <div class="bg-white/80 backdrop-blur-md border border-white rounded-[2.5rem] p-6 md:p-8 shadow-xl shadow-primary/10 flex flex-col gap-5">
                <div class="flex flex-wrap gap-3 items-center justify-between">
                    <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-text-muted">Diagram Canvas</label>
                    <div class="flex flex-wrap gap-2">
                        <button @click="zoomOut()" class="px-3 py-2 rounded-xl bg-white border border-stone-200 text-text-muted font-bold text-xs hover:border-primary hover:text-primary transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">zoom_out</span>
                            Zoom Out
                        </button>
                        <button @click="zoomIn()" class="px-3 py-2 rounded-xl bg-white border border-stone-200 text-text-muted font-bold text-xs hover:border-primary hover:text-primary transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">zoom_in</span>
                            Zoom In
                        </button>
                        <button @click="resetView()" class="px-3 py-2 rounded-xl bg-white border border-stone-200 text-text-muted font-bold text-xs hover:border-primary hover:text-primary transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">center_focus_strong</span>
                            Reset View
                        </button>
                    </div>
                </div>

                <div class="relative bg-stone-50 border-2 border-stone-100 rounded-2xl overflow-hidden" style="resize: vertical; min-height: 420px; height: 420px;">
                    <div class="absolute top-3 left-3 z-10 px-3 py-1.5 rounded-full bg-white/90 border border-stone-200 text-[10px] uppercase tracking-wider font-bold text-text-muted">
                        Drag to pan • Scroll to zoom
                    </div>
                    <div x-ref="diagramViewport" class="w-full h-full p-4 overflow-hidden"></div>
                </div>

                <div class="flex flex-wrap gap-3 justify-end">
                    <button @click="downloadSvg()" :disabled="!hasDiagram" :class="hasDiagram ? 'opacity-100' : 'opacity-40 cursor-not-allowed'" class="px-4 py-2 rounded-xl bg-white border border-stone-200 text-text-main font-bold text-xs uppercase tracking-wider hover:border-primary hover:text-primary transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">description</span>
                        Download SVG
                    </button>
                    <button @click="downloadPng()" :disabled="!hasDiagram" :class="hasDiagram ? 'opacity-100' : 'opacity-40 cursor-not-allowed'" class="px-4 py-2 rounded-xl bg-text-main text-white font-bold text-xs uppercase tracking-wider hover:bg-primary transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">download</span>
                        Download PNG
                    </button>
                </div>
            </div>
        </div>

        {# Cheatsheet #}
        <aside class="xl:col-span-4 flex flex-col gap-6">
            <div class="bg-white/80 backdrop-blur-md border border-white rounded-[2.5rem] p-6 shadow-xl shadow-primary/10" x-data="{ open: {} }">
                <div class="flex items-center gap-2 mb-4 text-xs font-bold uppercase tracking-widest text-text-main">
                    <span class="material-symbols-outlined text-primary">menu_book</span>
                    Mermaid Cheatsheet
                </div>

                <div class="space-y-4 text-xs">

                    <div class="px-1">
                        <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-text-muted">Common Diagrams</p>
                    </div>

                    {# Flowchart #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.flowchart = !open.flowchart">
                            <span class="font-bold text-text-main text-xs">Flowchart</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('flowchart')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'flowchart' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'flowchart' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.flowchart ? 'rotate-180' : ''" @click="open.flowchart = !open.flowchart">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.flowchart" style="display:none">
                            <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">flowchart TD
A[Start] --> B{Decision}
B -->|Yes| C[OK]
B -->|No| D[Retry]
C --> E([End])
D --> A</pre>
                        </div>
                    </div>

                    {# Line/Bar Chart #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.comboChart = !open.comboChart">
                            <span class="font-bold text-text-main text-xs">Line/Bar Chart</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('comboChart')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'comboChart' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'comboChart' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.comboChart ? 'rotate-180' : ''" @click="open.comboChart = !open.comboChart">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.comboChart" style="display:none">
                            <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">xychart-beta
  title "Traffic vs Conversion"
  x-axis [Jan, Feb, Mar, Apr, May, Jun]
  y-axis "Volume" 0 --> 220
  bar [120, 140, 165, 172, 185, 210]
  line [18, 21, 26, 29, 33, 38]</pre>
                        </div>
                    </div>

                    {# Mindmap #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.mindmap = !open.mindmap">
                            <span class="font-bold text-text-main text-xs">Mindmap</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('mindmap')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'mindmap' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'mindmap' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.mindmap ? 'rotate-180' : ''" @click="open.mindmap = !open.mindmap">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.mindmap" style="display:none">
                            <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">mindmap
    root((Product Platform))
    User Experience
        Web
        Mobile
        Accessibility
    Engineering
        Frontend
        Backend
        Platform
    Growth
        SEO
        Partnerships
        Community
    Observability
        Logs
        Metrics
        Traces</pre>
                        </div>
                    </div>

                    {# Pie Chart #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.pie = !open.pie">
                            <span class="font-bold text-text-main text-xs">Pie Chart</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('pie')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'pie' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'pie' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.pie ? 'rotate-180' : ''" @click="open.pie = !open.pie">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.pie" style="display:none">
                            <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">pie title Engineering Time Allocation
    "Feature Delivery" : 45
    "Bug Fixing" : 20
    "Tech Debt" : 15
    "Code Review" : 10
    "Meetings" : 10</pre>
                        </div>
                    </div>

                    <div class="px-1 pt-1">
                        <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-text-muted">Engineer Diagrams</p>
                    </div>

                    {# Architecture #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.architectureSimple = !open.architectureSimple">
                            <span class="font-bold text-text-main text-xs">Architecture</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('architectureSimple')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'architectureSimple' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'architectureSimple' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.architectureSimple ? 'rotate-180' : ''" @click="open.architectureSimple = !open.architectureSimple">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.architectureSimple" style="display:none">
                            <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">architecture-beta
  group devops(cloud)[GitHub]
  service repo(server)[Repository] in devops
  service cicd(server)[Actions CICD] in devops

  group cloudflare(cloud)[Cloudflare Stack]
  service proxy(cloud)[Proxy DNS] in cloudflare
  service worker(server)[Workers] in cloudflare
  service d1(database)[D1 Database] in cloudflare
  service r2(disk)[R2 Storage] in cloudflare
  service kv(disk)[KV] in cloudflare
  service logs(disk)[Logs Analytics] in cloudflare

  service client(internet)[Client]

  client:R --> L:proxy
  repo:R --> L:cicd
  cicd:B --> T:worker
  proxy:R --> L:worker
  worker:R --> L:d1
  worker:R --> L:r2
  worker:R --> L:kv
  worker:B --> T:logs</pre>
                        </div>
                    </div>

                    {# Block Diagram #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.flutterBlock = !open.flutterBlock">
                            <span class="font-bold text-text-main text-xs">Block Diagram</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('flutterBlock')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'flutterBlock' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'flutterBlock' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.flutterBlock ? 'rotate-180' : ''" @click="open.flutterBlock = !open.flutterBlock">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.flutterBlock" style="display:none">
                                                                                                                <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">block
    columns 3
    a:3
    block:group1:2
        columns 2
        h i
        j k
    end
    g
    block:group2:3
        l m n o p q r
    end</pre>
                        </div>
                    </div>

                    {# Class Diagram #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.classDiagram = !open.classDiagram">
                            <span class="font-bold text-text-main text-xs">Class Diagram</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('class')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'class' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'class' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.classDiagram ? 'rotate-180' : ''" @click="open.classDiagram = !open.classDiagram">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.classDiagram" style="display:none">
                            <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">classDiagram
  class Animal {
    +String name
    +int age
    +eat() void
    +sleep() void
  }
  class Flyable {
    &lt;&lt;interface&gt;&gt;
    +fly() void
  }
  class Dog {
    +String breed
    +bark() void
  }
  class Bird {
    +String species
    +fly() void
  }
  Animal <|-- Dog : extends
  Animal <|-- Bird : extends
  Flyable <|.. Bird : implements
  Dog "1" --> "*" Owner : belongsTo</pre>
                        </div>
                    </div>

                    {# DB Diagram #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.dbDiagram = !open.dbDiagram">
                            <span class="font-bold text-text-main text-xs">DB Diagram (ER)</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('dbDiagram')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'dbDiagram' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'dbDiagram' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.dbDiagram ? 'rotate-180' : ''" @click="open.dbDiagram = !open.dbDiagram">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.dbDiagram" style="display:none">
                            <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">erDiagram
    USERS ||--o{ SESSIONS : has
    USERS ||--o{ ORDERS : places
    ORDERS ||--|{ ORDER_ITEMS : contains
    PRODUCTS ||--o{ ORDER_ITEMS : referenced_by
    ORDERS }o--|| ADDRESSES : ships_to
    USERS ||--o{ ADDRESSES : owns

    USERS {
        uuid id PK
        string email
        string full_name
        datetime created_at
    }

    ORDERS {
        uuid id PK
        uuid user_id FK
        string status
        decimal total_amount
        datetime created_at
    }

    PRODUCTS {
        uuid id PK
        string name
        decimal price
        int stock
    }</pre>
                        </div>
                    </div>

                    {# Folder Structure #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.treeview = !open.treeview">
                            <span class="font-bold text-text-main text-xs">Folder Structure</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('treeview')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'treeview' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'treeview' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.treeview ? 'rotate-180' : ''" @click="open.treeview = !open.treeview">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.treeview" style="display:none">
                            <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">treeView-beta
    "Company"
        "Engineering"
            "Backend Team"
                "Platform Squad"
                "Payments Squad"
            "Frontend Team"
                "Web App Squad"
            "Mobile Team"
        "Product"
        "Operations"
            "SRE"
            "Customer Support"</pre>
                        </div>
                    </div>

                    {# Git Graph #}
                    <div class="rounded-2xl border border-stone-100 overflow-hidden">
                        <div class="flex items-center justify-between gap-2 px-4 py-3 bg-stone-50 hover:bg-stone-100 transition-colors cursor-pointer select-none" @click="open.gitgraph = !open.gitgraph">
                            <span class="font-bold text-text-main text-xs">Git Graph</span>
                            <div class="flex items-center gap-2" @click.stop>
                                <button @click="useCheat('gitgraph')" class="px-2 py-0.5 rounded-lg border border-stone-200 bg-white text-[10px] font-bold uppercase tracking-wider text-text-muted hover:text-primary hover:border-primary transition-colors flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs" x-text="usedCheat === 'gitgraph' ? 'check' : 'arrow_upward'"></span>
                                    <span x-text="usedCheat === 'gitgraph' ? 'Applied' : 'Use'"></span>
                                </button>
                                <span class="material-symbols-outlined text-stone-400 text-base transition-transform duration-200" :class="open.gitgraph ? 'rotate-180' : ''" @click="open.gitgraph = !open.gitgraph">expand_more</span>
                            </div>
                        </div>
                        <div x-show="open.gitgraph" style="display:none">
                            <pre class="font-mono text-[11px] text-text-muted overflow-x-auto px-4 py-3 bg-white border-t border-stone-100">gitGraph
  commit id: "init"
  branch develop
  checkout develop
