---
layout: layouts/base.njk
title: Take-home Pay (IDR)
description: Calculate monthly take-home pay in Indonesia (PPh21, BPJS, JHT, pension).
permalink: /tools/salary/
---

<div class="w-full max-w-4xl flex flex-col gap-12" x-data="salaryTool()" x-init="init()">
    {# Header #}
    {% set tool = {} %}
    {% for item in site.pages.tools.list %}
        {% if item.url == "/tools/salary/" %}
            {% set tool = item %}
        {% endif %}
    {% endfor %}
    {% set cat = site.pages.tools.categories[tool.tag] %}

    <div class="flex flex-col gap-4 text-center items-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border {{ cat.color }}">
            <span class="material-symbols-outlined text-sm">{{ cat.icon }}</span>
            {{ tool.tag }}
        </div>
        <div class="w-16 h-16 rounded-2xl {{ cat.lightColor }} flex items-center justify-center mb-2">
            <span class="material-symbols-outlined text-4xl">{{ tool.icon }}</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-text-main font-display">
            {{ tool.title }}
        </h1>
        <p class="text-lg text-text-muted max-w-xl leading-relaxed">
            {{ tool.description }}
        </p>
    </div>

    <div class="bg-white/80 backdrop-blur-md border border-white rounded-[2.5rem] p-8 md:p-12 shadow-2xl shadow-primary/10 transition-all duration-500">
        <div class="flex flex-col gap-8">
            <div class="rounded-2xl border border-primary/20 bg-primary/[0.06] p-4 md:p-5 flex items-start gap-3">
                <span class="material-symbols-outlined text-primary text-xl mt-0.5">tips_and_updates</span>
                <div>
                    <div class="text-xs font-bold uppercase tracking-wider text-text-main">Input Shortcut</div>
                    <p class="mt-1 text-sm text-text-muted leading-relaxed">You can type shorthand values in salary fields: <span class="font-semibold text-text-main">250k</span>, <span class="font-semibold text-text-main">1.5m</span>, or <span class="font-semibold text-text-main">1.2b</span> (case-insensitive).</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">Monthly Gross Salary (IDR)</label>
                    <input type="text" x-model="inputs.monthlyGross" @input="onCurrencyInput('monthlyGross')" @blur="onCurrencyBlur('monthlyGross')" placeholder="0" class="block w-full px-6 py-4 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main focus:outline-none text-lg" />
                </div>

                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">Other Monthly Allowances (optional)</label>
                    <input type="text" x-model="inputs.monthlyAllowance" @input="onCurrencyInput('monthlyAllowance')" @blur="onCurrencyBlur('monthlyAllowance')" placeholder="0" class="block w-full px-6 py-4 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main focus:outline-none text-lg" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">Marital Status</label>
                    <div class="flex items-center gap-3">
                        <div class="inline-flex rounded-full border-2 p-1 bg-stone-50" role="tablist" aria-label="Marital status">
                            <button :class="status.married ? 'text-text-muted' : 'bg-primary text-white shadow'" @click="status.married=false; recalculate()" class="px-3 py-1 rounded-full text-sm font-bold">Single</button>
                            <button :class="status.married ? 'bg-primary text-white shadow' : 'text-text-muted'" @click="status.married=true; recalculate()" class="px-3 py-1 rounded-full text-sm font-bold">Married</button>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col gap-2 md:col-span-2">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">Number of Dependents (children, max 3)</label>
                    <input type="number" min="0" max="3" x-model.number="status.dependents" @input="recalculate()" class="w-24 px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">BPJS Kesehatan (employee %)</label>
                        <input type="text" x-model="rateInputs.bpjs" @input="onRateInput('bpjs')" @blur="onRateBlur('bpjs')" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                </div>
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">JHT (employee %)</label>
                        <input type="text" x-model="rateInputs.jht" @input="onRateInput('jht')" @blur="onRateBlur('jht')" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                </div>
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">Pension (employee %)</label>
                        <input type="text" x-model="rateInputs.pension" @input="onRateInput('pension')" @blur="onRateBlur('pension')" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">BPJS Kesehatan (employer %)</label>
                    <input type="text" x-model="rateInputs.bpjsEmployer" @input="onRateInput('bpjsEmployer')" @blur="onRateBlur('bpjsEmployer')" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                </div>
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">JHT (employer %)</label>
                    <input type="text" x-model="rateInputs.jhtEmployer" @input="onRateInput('jhtEmployer')" @blur="onRateBlur('jhtEmployer')" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                </div>
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">JP/Pension (employer %)</label>
                    <input type="text" x-model="rateInputs.pensionEmployer" @input="onRateInput('pensionEmployer')" @blur="onRateBlur('pensionEmployer')" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">JKK Risk Classification (employer)</label>
                    <select x-model="jkkTier" @change="recalculate()" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main">
                        <template x-for="tier in jkkTiers" :key="tier.tier">
                            <option :value="tier.tier" x-text="tier.label"></option>
                        </template>
                    </select>
                    <p class="text-xs text-text-muted ml-1">PP 44/2015 — rate fixed by company's industry risk group</p>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">JKM / Death Insurance (employer %)</label>
                    <input type="text" x-model="rateInputs.jkm" @input="onRateInput('jkm')" @blur="onRateBlur('jkm')" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                    <p class="text-xs text-text-muted ml-1">PP 44/2015 — fixed at 0.30% for all companies</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">BPJS Kesehatan wage cap (IDR)</label>
                    <input type="text" x-model="capInputs.bpjs" @input="onCapInput('bpjs')" @blur="onCapBlur('bpjs')" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                    <p class="text-xs text-text-muted ml-1">Perpres 64/2020 — employee contribution capped at the salary limit above</p>
                </div>
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-bold uppercase tracking-widest text-text-muted ml-1">JP/Pension wage cap (IDR)</label>
                    <input type="text" x-model="capInputs.pension" @input="onCapInput('pension')" @blur="onCapBlur('pension')" class="block w-full px-4 py-3 bg-stone-50 border-2 border-stone-100 rounded-2xl text-text-main" />
                    <p class="text-xs text-text-muted ml-1">PP 45/2015 — batas atas upah, updated yearly by Permenaker</p>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <button @click="reset()" class="px-6 py-3 rounded-2xl bg-stone-100 text-text-muted border">Reset</button>
            </div>

            <div class="bg-stone-50 p-5 md:p-6 rounded-2xl border border-stone-100">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-white/80 border border-stone-200 rounded-2xl p-5">
                        <div class="text-xs font-bold uppercase tracking-widest text-text-muted">Monthly Breakdown</div>
                        <div class="mt-4 font-mono">
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="text-stone-600">Gross</span><span class="font-semibold text-right" x-text="format(m.monthlyGross)"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="text-stone-500 text-sm">+ Employer contribs (BPJS/JHT/JP/JKK/JKM)</span><span class="font-semibold text-right text-sm" x-text="format(m.taxableGross - m.monthlyGross)"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1 text-[13px] leading-5 border-b border-stone-200 mb-1.5">
                                <span class="text-stone-500 italic">Taxable Gross (TER base)</span><span class="font-semibold text-right italic" x-text="format(m.taxableGross)"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="text-stone-600">BPJS Kesehatan</span><span class="font-semibold text-right" x-text="format(m.monthlyBPJS)"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="text-stone-600">JHT</span><span class="font-semibold text-right" x-text="format(m.monthlyJHT)"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="text-stone-600">Pension</span><span class="font-semibold text-right" x-text="format(m.monthlyPension)"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="text-stone-600">PPh21 (monthly)</span><span class="font-semibold text-right" x-text="format(m.monthlyTax)"></span>
                            </div>
                            <hr class="my-3 border-stone-200" />
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="font-bold text-text-main">Take-home</span><span class="font-bold text-right text-text-main" x-text="format(m.takeHome)"></span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white/80 border border-stone-200 rounded-2xl p-5">
                        <div class="text-xs font-bold uppercase tracking-widest text-text-muted">Annual Summary</div>
                        <div class="mt-4 font-mono">
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="text-stone-600 pr-2">Annual Gross</span><span class="font-semibold text-right tabular-nums whitespace-nowrap" x-text="format(m.annualGross)"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="text-stone-600 pr-2">Total BPJS/JHT/Pension</span><span class="font-semibold text-right tabular-nums whitespace-nowrap" x-text="format(m.annualContributions)"></span>
                            </div>
                            <div class="mt-1 rounded-xl bg-stone-50 border border-stone-200 px-3 py-2">
                                <div class="text-[11px] font-bold uppercase tracking-wider text-text-muted">TER Category &amp; Rate (PMK 168/2023)</div>
                                <div class="mt-1 text-xs md:text-sm leading-5 font-semibold text-text-main" x-text="'Category ' + m.terCategory + ' — ' + m.terRate + '%'"></div>
                            </div>
                            <hr class="my-3 border-stone-200" />
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 py-1.5 text-[15px] leading-6">
                                <span class="font-bold text-text-main pr-2">Est. Annual Tax</span><span class="font-bold text-right text-text-main tabular-nums whitespace-nowrap" x-text="format(m.annualTax)"></span>
                            </div>
                        </div>
                        <p class="mt-3 text-xs leading-5 text-text-muted">Tax uses TER method (flat monthly rate). December may differ slightly due to annual reconciliation.</p>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-stone-200 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="flex gap-3">
                        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-blue-50 flex items-center justify-center">
                            <span class="material-symbols-outlined text-blue-600 text-lg">gavel</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-text-main mb-1">Legal Reference</h3>
                            <p class="text-sm text-text-muted leading-relaxed">PPh 21 menggunakan metode TER (Tarif Efektif Rata-rata) per PMK 168/2023, berlaku sejak Januari 2024. Tarif ditentukan dari penghasilan bruto bulanan dan status PTKP (Kategori A/B/C).</p>
                            <p class="text-xs text-text-muted mt-1">Default employee rates: BPJS 1%, JHT 2%, JP 1%. Default employer rates: BPJS 4%, JHT 3.7%, JP 2%, JKK 0.24% (Kel. I), JKM 0.30%.</p>
                            <p class="text-xs text-text-muted mt-1">Wage caps: BPJS Kesehatan Rp 12.000.000 (Perpres 64/2020); JP batas atas Rp 10.547.400 (2026, Permenaker). JHT has no cap.</p>
                            <!-- Maintenance note: keep this date static and update it manually only after re-checking the latest PPh21/PTKP/BPJS regulations. Also update JP batas atas cap if Permenaker changes. -->
                            <p class="text-xs text-text-muted mt-1">Last checked: 20 Apr 2026.</p>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-amber-50 flex items-center justify-center">
                            <span class="material-symbols-outlined text-amber-600 text-lg">info</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-text-main mb-1">PTKP Rule</h3>
                            <p class="text-sm text-text-muted leading-relaxed">PTKP mengacu PMK No. 101/PMK.010/2016: TK/0 Rp54.000.000, tambahan kawin Rp4.500.000, tanggungan maksimal 3 orang x Rp4.500.000.</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="flex justify-center">
        <a href="/tools/" class="flex items-center gap-2 text-text-muted hover:text-primary transition-colors font-bold uppercase tracking-widest text-xs">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Back to Tools
        </a>
    </div>
</div>

<script>
    function salaryTool() {
        return {
            monthlyGross: 0,
            monthlyAllowance: 0,
            inputs: {
                monthlyGross: '0',
                monthlyAllowance: '0'
            },
            rates: {
                bpjs: 1.00, // percent, employee
                jht: 2.00,
                pension: 1.00,
                // Employer contributions — included in taxable gross for TER (PMK 168/2023 / UU HPP)
                jkk: 0.24,        // JKK/Accident Insurance, employer (PP 44/2015, tier-based, see jkkTier)
                jkm: 0.30,        // JKM/Death Insurance, employer (PP 44/2015, fixed)
                bpjsEmployer: 4.00, // BPJS Kesehatan employer (Perpres 64/2020, capped)
                jhtEmployer: 3.70,  // JHT employer (PP 46/2015)
                pensionEmployer: 2.00 // JP/Pension employer (PP 45/2015, capped)
            },
            rateInputs: {
                bpjs: '1.00',
                jht: '2.00',
                pension: '1.00',
                jkm: '0.30',
                bpjsEmployer: '4.00',
                jhtEmployer: '3.70',
                pensionEmployer: '2.00'
            },
            // JKK risk classification tiers per PP 44/2015 Lampiran I
            jkkTier: 1,
            jkkTiers: [
                { tier: 1, label: 'Kelompok I — 0.24% (Perkantoran / Office)', rate: 0.24 },
                { tier: 2, label: 'Kelompok II — 0.54% (Perdagangan / Trade)', rate: 0.54 },
                { tier: 3, label: 'Kelompok III — 0.89% (Industri ringan / Light industry)', rate: 0.89 },
                { tier: 4, label: 'Kelompok IV — 1.27% (Industri sedang / Medium industry)', rate: 1.27 },
                { tier: 5, label: 'Kelompok V — 1.74% (Industri berat / Heavy industry)', rate: 1.74 }
            ],
            // Wage caps: contribution base is capped at these amounts regardless of actual salary.
            // BPJS Kesehatan: Perpres 64/2020 Ps.32 — cap fixed at Rp 12,000,000.
            // JP (Jaminan Pensiun): PP 45/2015 — batas atas upah, updated each year via Permenaker.
            //   2024: Rp 9,559,600 | 2025: Rp 10,042,300 | 2026: Rp 10,547,400
            // JHT: no upper cap.
            caps: {
                bpjs: 12000000,
                pension: 10547400
            },
            capInputs: {
                bpjs: '12.000.000',
                pension: '10.547.400'
            },
            // TER (Tarif Efektif Rata-rata) tables per PMK 168/2023, effective Jan 2024.
            // Each entry: [upperBoundInclusive, ratePercent]. Income <= upper → that rate.
            // Category A: TK/0, TK/1, K/0  — verified vs payslip: 43.6M→16%, 44.315M→17%
            // Category B: TK/2, TK/3, K/1, K/2
            // Category C: K/3
            terTables: {
                A: [
                    [5400000,0],[5650000,0.25],[5950000,0.5],[6300000,0.75],
                    [6750000,1],[7500000,1.25],[8550000,1.5],[9650000,2],
                    [10050000,2.5],[10350000,3],[10700000,3.5],[11050000,4],
                    [11600000,4.5],[12500000,5],[13750000,5.5],[15100000,6],
                    [16950000,7],[19750000,8],[24150000,9],[26450000,10],
                    [28000000,11],[30050000,12],[32400000,13],[35400000,14],
                    [38900000,15],[44000000,16],[50000000,17],[56300000,18],
                    [62500000,19],[68600000,20],[77500000,21],[89000000,22],
                    [103000000,23],[125000000,24],[157000000,25],[206000000,26],
                    [337000000,28],[454000000,30],[550000000,32],[Infinity,34]
                ],
                B: [
                    [6200000,0],[6500000,0.25],[6850000,0.5],[7300000,0.75],
                    [9200000,1],[10750000,1.5],[11250000,2],[11600000,2.5],
                    [12600000,3],[13600000,4],[14950000,5],[16400000,6],
                    [18450000,7],[21850000,8],[26000000,9],[27700000,10],
                    [29350000,11],[31450000,12],[33950000,13],[37100000,14],
                    [41100000,15],[45800000,16],[51400000,17],[58500000,18],
                    [64000000,19],[71000000,20],[80000000,21],[93000000,22],
                    [109000000,23],[129000000,24],[163000000,25],[211000000,26],
                    [374000000,28],[459000000,30],[555000000,32],[Infinity,34]
                ],
                C: [
                    [6600000,0],[6950000,0.25],[7350000,0.5],[7800000,0.75],
                    [8850000,1],[9800000,1.25],[10950000,1.5],[11200000,2],
                    [12050000,3],[12950000,4],[14150000,5],[15550000,6],
                    [17050000,7],[19500000,8],[22700000,9],[29500000,10],
                    [30250000,11],[32550000,12],[35100000,13],[38600000,14],
                    [43350000,15],[47800000,16],[51400000,17],[56300000,18],
                    [62500000,19],[68600000,20],[77500000,21],[89000000,22],
                    [103000000,23],[125000000,24],[157000000,25],[206000000,26],
                    [337000000,28],[454000000,30],[550000000,32],[Infinity,34]
                ]
            },
            status: {
                married: false,
                dependents: 0
            },
            m: {
                monthlyGross: 0,
                taxableGross: 0,
                monthlyBPJS: 0,
                monthlyJHT: 0,
                monthlyPension: 0,
                monthlyTax: 0,
                takeHome: 0,
                annualGross: 0,
                annualContributions: 0,
                annualTax: 0,
                terCategory: '-',
                terRate: 0
            },

            format(v) {
                return new Intl.NumberFormat('id-ID').format(Math.round(v || 0));
            },

            init() {
                this.inputs.monthlyGross = this.format(this.monthlyGross);
                this.inputs.monthlyAllowance = this.format(this.monthlyAllowance);
                this.rateInputs.bpjs = this.formatPercent(this.rates.bpjs);
                this.rateInputs.jht = this.formatPercent(this.rates.jht);
                this.rateInputs.pension = this.formatPercent(this.rates.pension);
                this.rateInputs.jkm = this.formatPercent(this.rates.jkm);
                this.rateInputs.bpjsEmployer = this.formatPercent(this.rates.bpjsEmployer);
                this.rateInputs.jhtEmployer = this.formatPercent(this.rates.jhtEmployer);
                this.rateInputs.pensionEmployer = this.formatPercent(this.rates.pensionEmployer);
                this.capInputs.bpjs = this.format(this.caps.bpjs);
                this.capInputs.pension = this.format(this.caps.pension);
                this.recalculate();
            },

            formatPercent(v) {
                const n = Number(v || 0);
                if (!Number.isFinite(n)) return '0';
                return n.toFixed(2).replace(/\.00$/, '').replace(/(\.\d)0$/, '$1');
            },

            onCurrencyInput(field) {
                const value = this.parseCurrencyValue(this.inputs[field]);
                this[field] = value;
                this.recalculate();
            },

            onCurrencyBlur(field) {
                const value = this.parseCurrencyValue(this.inputs[field]);
                this[field] = value;
                this.inputs[field] = this.format(value);
                this.recalculate();
            },

            onRateInput(field) {
                const value = this.parseRateValue(this.rateInputs[field]);
                if (!Number.isNaN(value)) {
                    this.rates[field] = value;
                    this.recalculate();
                }
            },

            onRateBlur(field) {
                const value = this.parseRateValue(this.rateInputs[field]);
                this.rates[field] = Number.isNaN(value) ? 0 : value;
                this.rateInputs[field] = this.formatPercent(this.rates[field]);
                this.recalculate();
            },

            onCapInput(field) {
                const value = this.parseCurrencyValue(this.capInputs[field]);
                if (!Number.isNaN(value) && value > 0) {
                    this.caps[field] = value;
                    this.recalculate();
                }
            },

            onCapBlur(field) {
                const defaults = { bpjs: 12000000, pension: 10547400 };
                const value = this.parseCurrencyValue(this.capInputs[field]);
                this.caps[field] = (!Number.isNaN(value) && value > 0) ? value : defaults[field];
                this.capInputs[field] = this.format(this.caps[field]);
                this.recalculate();
            },

            parseRateValue(input) {
                const raw = String(input || '').trim();
                if (!raw) return 0;
                const cleaned = raw.replace(/[^0-9.,]/g, '');
                return this.parseLocalizedNumber(cleaned);
            },

            parseCurrencyValue(input) {
                const raw = String(input || '').trim();
                if (!raw) return 0;

                // Similar to Math Notes scale shortcuts: convert 250k/10m/1.2b to full numeric IDR.
                const shorthandMatch = raw.match(/^([\d.,]+)\s*([kKmMbB])$/);
                if (shorthandMatch) {
                    const base = this.parseLocalizedNumber(shorthandMatch[1]);
                    if (!Number.isNaN(base)) {
                        const suffix = shorthandMatch[2].toLowerCase();
                        const scale = suffix === 'k' ? 1000 : suffix === 'm' ? 1000000 : 1000000000;
                        return base * scale;
                    }
                }

                // Accept localized decimal/grouping input like 1.250.000,50 or 1250000.5.
                const normalized = this.parseLocalizedNumber(raw);
                if (!Number.isNaN(normalized)) {
                    return normalized;
                }

                // Final fallback: keep only digits for plain IDR input.
                const digitsOnly = raw.replace(/[^0-9]/g, '');
                return digitsOnly ? Number(digitsOnly) : 0;
            },

            parseLocalizedNumber(value) {
                const cleaned = String(value || '').trim().replace(/\s+/g, '');
                if (!cleaned || !/^\d[\d.,]*$/.test(cleaned)) return NaN;

                const hasDot = cleaned.includes('.');
                const hasComma = cleaned.includes(',');

                if (hasDot && hasComma) {
                    const decimalSep = cleaned.lastIndexOf('.') > cleaned.lastIndexOf(',') ? '.' : ',';
                    const thousandSep = decimalSep === '.' ? ',' : '.';
                    const normalized = cleaned.replace(new RegExp(`\\${thousandSep}`, 'g'), '').replace(decimalSep, '.');
                    return Number(normalized);
                }

                if (hasComma) {
                    const parts = cleaned.split(',');
                    const decimalLike = parts.length === 2 && parts[1].length > 0 && parts[1].length !== 3;
                    return Number(decimalLike ? cleaned.replace(',', '.') : cleaned.replace(/,/g, ''));
                }

                if (hasDot) {
                    const parts = cleaned.split('.');
                    const decimalLike = parts.length === 2 && parts[1].length > 0 && parts[1].length !== 3;
                    return Number(decimalLike ? cleaned : cleaned.replace(/\./g, ''));
                }

                return Number(cleaned);
            },

            reset() {
                this.monthlyGross = 0;
                this.monthlyAllowance = 0;
                this.inputs.monthlyGross = '0';
                this.inputs.monthlyAllowance = '0';
                this.jkkTier = 1;
                this.rates = { bpjs:1.00, jht:2.00, pension:1.00, jkk:0.24, jkm:0.30, bpjsEmployer:4.00, jhtEmployer:3.70, pensionEmployer:2.00 };
                this.rateInputs.bpjs = this.formatPercent(this.rates.bpjs);
                this.rateInputs.jht = this.formatPercent(this.rates.jht);
                this.rateInputs.pension = this.formatPercent(this.rates.pension);
                this.rateInputs.jkm = this.formatPercent(this.rates.jkm);
                this.rateInputs.bpjsEmployer = this.formatPercent(this.rates.bpjsEmployer);
                this.rateInputs.jhtEmployer = this.formatPercent(this.rates.jhtEmployer);
                this.rateInputs.pensionEmployer = this.formatPercent(this.rates.pensionEmployer);
                this.caps = { bpjs: 12000000, pension: 10547400 };
                this.capInputs.bpjs = this.format(this.caps.bpjs);
                this.capInputs.pension = this.format(this.caps.pension);
                this.recalculate();
            },

            computePTKP() {
                const base = 54000000;
                const spouse = this.status.married ? 4500000 : 0;
                const dependents = Math.min(Math.max(Number(this.status.dependents || 0), 0), 3) * 4500000;
                return base + spouse + dependents;
            },

            getTERCategory() {
                const deps = Math.min(Math.max(Number(this.status.dependents || 0), 0), 3);
                if (this.status.married && deps === 3) return 'C';
                if ((!this.status.married && deps >= 2) || (this.status.married && deps >= 1)) return 'B';
                return 'A'; // TK/0, TK/1, K/0
            },

            lookupTER(gross) {
                const cat = this.getTERCategory();
                const table = this.terTables[cat];
                for (let i = 0; i < table.length; i++) {
                    if (gross <= table[i][0]) return { rate: table[i][1], category: cat };
                }
                return { rate: 34, category: cat };
            },

            recalculate() {
                const gross = Number(this.monthlyGross || 0);
                const allowance = Number(this.monthlyAllowance || 0);
                const monthlyGrossTotal = gross + allowance;

                // Apply wage caps: BPJS Kesehatan capped at Rp 12,000,000 (Perpres 64/2020),
                // JP (pension) capped at batas atas upah set by Permenaker each year.
                // JHT has no upper cap.
                const bpjsBase = Math.min(monthlyGrossTotal, this.caps.bpjs);
                const pensionBase = Math.min(monthlyGrossTotal, this.caps.pension);

                // Employee deductions (subtracted from pay)
                const bpjsMonthly = bpjsBase * (this.rates.bpjs/100);
                const jhtMonthly = monthlyGrossTotal * (this.rates.jht/100);
                const pensionMonthly = pensionBase * (this.rates.pension/100);

                // Employer contributions included in taxable gross per PMK 168/2023:
                // BPJS Kesehatan employer, JKK, JKM.
                // JHT employer and JP employer are NOT included per common payroll practice.
                const selectedTier = this.jkkTiers.find(t => t.tier === Number(this.jkkTier)) || this.jkkTiers[0];
                const jkkRate = selectedTier.rate;
                const jkkMonthly = monthlyGrossTotal * (jkkRate/100);
                const jkmMonthly = monthlyGrossTotal * (this.rates.jkm/100);
                const bpjsEmployerMonthly = bpjsBase * (this.rates.bpjsEmployer/100);
                const jhtEmployerMonthly = monthlyGrossTotal * (this.rates.jhtEmployer/100);
                const pensionEmployerMonthly = pensionBase * (this.rates.pensionEmployer/100);
                const taxableGross = monthlyGrossTotal + jkkMonthly + jkmMonthly + bpjsEmployerMonthly;

                const annualGross = monthlyGrossTotal * 12;
                const annualBPJS = bpjsMonthly * 12;
                const annualJHT = jhtMonthly * 12;
                const annualPension = pensionMonthly * 12;

                // PMK 168/2023: monthly PPh21 = taxable gross × TER rate.
                const ter = this.lookupTER(taxableGross);
                const monthlyTax = taxableGross * ter.rate / 100;
                const annualTax = monthlyTax * 12;
                // Take-home: basic gross minus employee deductions and tax (employer items net to zero)
                const takeHome = monthlyGrossTotal - bpjsMonthly - jhtMonthly - pensionMonthly - monthlyTax;

                this.m = {
                    monthlyGross: monthlyGrossTotal,
                    taxableGross: taxableGross,
                    monthlyBPJS: bpjsMonthly,
                    monthlyJHT: jhtMonthly,
                    monthlyPension: pensionMonthly,
                    monthlyTax: monthlyTax,
                    takeHome: takeHome,
                    annualGross: annualGross,
                    annualContributions: annualBPJS + annualJHT + annualPension,
                    annualTax: annualTax,
                    terCategory: ter.category,
                    terRate: ter.rate
                };
            }
        }
    }
</script>
