<script>
    function salaryTool() {
        return {
            monthlyGross: 0,
            monthlyAllowance: 0,
            inputs: {
                monthlyGross: '',
                monthlyAllowance: ''
            },
            rates: {
                bpjs: 1.00, // percent, employee
                jht: 2.00,
                pension: 1.00,
                // Employer contributions — included in taxable gross for TER (PMK 168/2023 / UU HPP)
                jkk: 0.24,        // JKK/Accident Insurance, employer (PP 44/2015, tier-based, see jkkTier)
                jkm: 0.30,        // JKM/Death Insurance, employer (PP 44/2015, fixed)
                bpjsEmployer: 4.00, // BPJS Kesehatan employer (Perpres 64/2020, capped)
                jhtEmployer: 3.70,  // JHT employer (PP 46/2015)
                pensionEmployer: 2.00 // JP/Pension employer (PP 45/2015, capped)
            },
            rateInputs: {
                bpjs: '1.00',
                jht: '2.00',
                pension: '1.00',
                jkm: '0.30',
                bpjsEmployer: '4.00',
                jhtEmployer: '3.70',
                pensionEmployer: '2.00'
            },
            // JKK risk classification tiers per PP 44/2015 Lampiran I
            jkkTier: 1,
            jkkTiers: [
                { tier: 1, name: 'Sangat Rendah (Perkantoran / Office)', label: 'Kel. I', rate: 0.24 },
                { tier: 2, name: 'Rendah (Perdagangan / Trade)', label: 'Kel. II', rate: 0.54 },
                { tier: 3, name: 'Sedang (Industri Ringan)', label: 'Kel. III', rate: 0.89 },
                { tier: 4, name: 'Tinggi (Industri Sedang)', label: 'Kel. IV', rate: 1.27 },
                { tier: 5, name: 'Sangat Tinggi (Industri Berat)', label: 'Kel. V', rate: 1.74 }
            ],
            // Wage caps: contribution base is capped at these amounts regardless of actual salary.
            // BPJS Kesehatan: Perpres 64/2020 Ps.32 — cap fixed at Rp 12,000,000.
            // JP (Jaminan Pensiun): PP 45/2015 — batas atas upah, updated each year via Permenaker.
            //   2024: Rp 9,559,600 | 2025: Rp 10,042,300 | 2026: Rp 10,547,400
            // JHT: no upper cap.
            caps: {
                bpjs: 12000000,
                pension: 10547400
            },
            capInputs: {
                bpjs: '12.000.000',
                pension: '10.547.400'
            },
            // TER (Tarif Efektif Rata-rata) tables per PMK 168/2023, effective Jan 2024.
            // Each entry: [upperBoundInclusive, ratePercent]. Income <= upper → that rate.
            // Category A: TK/0, TK/1, K/0  — verified vs payslip: 43.6M→16%, 44.315M→17%
            // Category B: TK/2, TK/3, K/1, K/2
            // Category C: K/3
            terTables: {
                A: [
                    [5400000,0],[5650000,0.25],[5950000,0.5],[6300000,0.75],
                    [6750000,1],[7500000,1.25],[8550000,1.5],[9650000,2],
                    [10050000,2.5],[10350000,3],[10700000,3.5],[11050000,4],
                    [11600000,4.5],[12500000,5],[13750000,5.5],[15100000,6],
                    [16950000,7],[19750000,8],[24150000,9],[26450000,10],
                    [28000000,11],[30050000,12],[32400000,13],[35400000,14],
                    [38900000,15],[44000000,16],[50000000,17],[56300000,18],
                    [62500000,19],[68600000,20],[77500000,21],[89000000,22],
                    [103000000,23],[125000000,24],[157000000,25],[206000000,26],
                    [337000000,28],[454000000,30],[550000000,32],[Infinity,34]
                ],
                B: [
                    [6200000,0],[6500000,0.25],[6850000,0.5],[7300000,0.75],
                    [9200000,1],[10750000,1.5],[11250000,2],[11600000,2.5],
                    [12600000,3],[13600000,4],[14950000,5],[16400000,6],
                    [18450000,7],[21850000,8],[26000000,9],[27700000,10],
                    [29350000,11],[31450000,12],[33950000,13],[37100000,14],
                    [41100000,15],[45800000,16],[51400000,17],[58500000,18],
                    [64000000,19],[71000000,20],[80000000,21],[93000000,22],
                    [109000000,23],[129000000,24],[163000000,25],[211000000,26],
                    [374000000,28],[459000000,30],[555000000,32],[Infinity,34]
                ],
                C: [
                    [6600000,0],[6950000,0.25],[7350000,0.5],[7800000,0.75],
                    [8850000,1],[9800000,1.25],[10950000,1.5],[11200000,2],
                    [12050000,3],[12950000,4],[14150000,5],[15550000,6],
                    [17050000,7],[19500000,8],[22700000,9],[29500000,10],
                    [30250000,11],[32550000,12],[35100000,13],[38600000,14],
                    [43350000,15],[47800000,16],[51400000,17],[56300000,18],
                    [62500000,19],[68600000,20],[77500000,21],[89000000,22],
                    [103000000,23],[125000000,24],[157000000,25],[206000000,26],
                    [337000000,28],[454000000,30],[550000000,32],[Infinity,34]
                ]
            },
            status: {
                married: false,
                dependents: 0
            },
            m: {
                monthlyGross: 0,
                taxableGross: 0,
                monthlyBPJS: 0,
                monthlyJHT: 0,
                monthlyPension: 0,
                monthlyTax: 0,
                takeHome: 0,
                annualGross: 0,
                annualContributions: 0,
                annualTax: 0,
                terCategory: '-',
                terRate: 0
            },

            format(v) {
                return new Intl.NumberFormat('id-ID').format(Math.round(v || 0));
            },

            init() {
                this.inputs.monthlyGross = this.monthlyGross > 0 ? this.format(this.monthlyGross) : '';
                this.inputs.monthlyAllowance = this.monthlyAllowance > 0 ? this.format(this.monthlyAllowance) : '';
                this.rateInputs.bpjs = this.formatPercent(this.rates.bpjs);
                this.rateInputs.jht = this.formatPercent(this.rates.jht);
                this.rateInputs.pension = this.formatPercent(this.rates.pension);
                this.rateInputs.jkm = this.formatPercent(this.rates.jkm);
                this.rateInputs.bpjsEmployer = this.formatPercent(this.rates.bpjsEmployer);
                this.rateInputs.jhtEmployer = this.formatPercent(this.rates.jhtEmployer);
                this.rateInputs.pensionEmployer = this.formatPercent(this.rates.pensionEmployer);
                this.capInputs.bpjs = this.format(this.caps.bpjs);
                this.capInputs.pension = this.format(this.caps.pension);
                this.recalculate();
            },

            formatPercent(v) {
                const n = Number(v || 0);
                if (!Number.isFinite(n)) return '0';
                return n.toFixed(2).replace(/\.00$/, '').replace(/(\.\d)0$/, '$1');
            },

            onCurrencyInput(field) {
                const raw = String(this.inputs[field] || '').trim();
                if (!raw) {
                    this[field] = 0;
                    this.inputs[field] = '';
                    this.recalculate();
                    return;
                }
                const value = this.parseCurrencyValue(this.inputs[field]);
                this[field] = value;
                this.inputs[field] = raw;
                this.recalculate();
            },

            onCurrencyBlur(field) {
                const raw = String(this.inputs[field] || '').trim();
                if (!raw) {
                    this[field] = 0;
                    this.inputs[field] = '';
                    this.recalculate();
                    return;
                }
                const value = this.parseCurrencyValue(this.inputs[field]);
                this[field] = value;
                this.inputs[field] = value > 0 ? this.format(value) : '';
                this.recalculate();
            },

            onRateInput(field) {
                const value = this.parseRateValue(this.rateInputs[field]);
                if (!Number.isNaN(value)) {
                    this.rates[field] = value;
                    this.recalculate();
                }
            },

            onRateBlur(field) {
                const value = this.parseRateValue(this.rateInputs[field]);
                this.rates[field] = Number.isNaN(value) ? 0 : value;
                this.rateInputs[field] = this.formatPercent(this.rates[field]);
                this.recalculate();
            },

            onCapInput(field) {
                const value = this.parseCurrencyValue(this.capInputs[field]);
                if (!Number.isNaN(value) && value > 0) {
                    this.caps[field] = value;
                    this.recalculate();
                }
            },

            onCapBlur(field) {
                const defaults = { bpjs: 12000000, pension: 10547400 };
                const value = this.parseCurrencyValue(this.capInputs[field]);
                this.caps[field] = (!Number.isNaN(value) && value > 0) ? value : defaults[field];
                this.capInputs[field] = this.format(this.caps[field]);
                this.recalculate();
            },

            parseRateValue(input) {
                const raw = String(input || '').trim();
                if (!raw) return 0;
                const cleaned = raw.replace(/[^0-9.,]/g, '');
                return this.parseLocalizedNumber(cleaned);
            },

            parseCurrencyValue(input) {
                const raw = String(input || '').trim();
                if (!raw) return 0;

                // Similar to Math Notes scale shortcuts: convert 250k/10m/1.2b to full numeric IDR.
                const shorthandMatch = raw.match(/^([\d.,]+)\s*([kKmMbB])$/);
                if (shorthandMatch) {
                    const base = this.parseLocalizedNumber(shorthandMatch[1]);
                    if (!Number.isNaN(base)) {
                        const suffix = shorthandMatch[2].toLowerCase();
                        const scale = suffix === 'k' ? 1000 : suffix === 'm' ? 1000000 : 1000000000;
                        return base * scale;
                    }
                }

                // Accept localized decimal/grouping input like 1.250.000,50 or 1250000.5.
                const normalized = this.parseLocalizedNumber(raw);
                if (!Number.isNaN(normalized)) {
                    return normalized;
                }

                // Final fallback: keep only digits for plain IDR input.
                const digitsOnly = raw.replace(/[^0-9]/g, '');
                return digitsOnly ? Number(digitsOnly) : 0;
            },

            parseLocalizedNumber(value) {
                const cleaned = String(value || '').trim().replace(/\s+/g, '');
                if (!cleaned || !/^\d[\d.,]*$/.test(cleaned)) return NaN;

                const hasDot = cleaned.includes('.');
                const hasComma = cleaned.includes(',');

                if (hasDot && hasComma) {
                    const decimalSep = cleaned.lastIndexOf('.') > cleaned.lastIndexOf(',') ? '.' : ',';
                    const thousandSep = decimalSep === '.' ? ',' : '.';
                    const normalized = cleaned.replace(new RegExp(`\\${thousandSep}`, 'g'), '').replace(decimalSep, '.');
                    return Number(normalized);
                }

                if (hasComma) {
                    const parts = cleaned.split(',');
                    const decimalLike = parts.length === 2 && parts[1].length > 0 && parts[1].length !== 3;
                    return Number(decimalLike ? cleaned.replace(',', '.') : cleaned.replace(/,/g, ''));
                }

                if (hasDot) {
                    const parts = cleaned.split('.');
                    const decimalLike = parts.length === 2 && parts[1].length > 0 && parts[1].length !== 3;
                    return Number(decimalLike ? cleaned : cleaned.replace(/\./g, ''));
                }

                return Number(cleaned);
            },

            reset() {
                this.monthlyGross = 0;
                this.monthlyAllowance = 0;
                this.inputs.monthlyGross = '';
                this.inputs.monthlyAllowance = '';
                this.jkkTier = 1;
                this.status = { married: false, dependents: 0 };
                this.rates = { bpjs:1.00, jht:2.00, pension:1.00, jkk:0.24, jkm:0.30, bpjsEmployer:4.00, jhtEmployer:3.70, pensionEmployer:2.00 };
                this.rateInputs.bpjs = this.formatPercent(this.rates.bpjs);
                this.rateInputs.jht = this.formatPercent(this.rates.jht);
                this.rateInputs.pension = this.formatPercent(this.rates.pension);
                this.rateInputs.jkm = this.formatPercent(this.rates.jkm);
                this.rateInputs.bpjsEmployer = this.formatPercent(this.rates.bpjsEmployer);
                this.rateInputs.jhtEmployer = this.formatPercent(this.rates.jhtEmployer);
                this.rateInputs.pensionEmployer = this.formatPercent(this.rates.pensionEmployer);
                this.caps = { bpjs: 12000000, pension: 10547400 };
                this.capInputs.bpjs = this.format(this.caps.bpjs);
                this.capInputs.pension = this.format(this.caps.pension);
                this.recalculate();
            },

            getTERCategory() {
                const deps = Math.min(Math.max(Number(this.status.dependents || 0), 0), 3);
                if (this.status.married && deps === 3) return 'C';
                if ((!this.status.married && deps >= 2) || (this.status.married && deps >= 1)) return 'B';
                return 'A'; // TK/0, TK/1, K/0
            },

            getPTKPCode() {
                const prefix = this.status.married ? 'K' : 'TK';
                const deps = Math.min(Math.max(Number(this.status.dependents || 0), 0), 3);
                return `${prefix}/${deps}`;
            },

            lookupTER(gross) {
                const cat = this.getTERCategory();
                const table = this.terTables[cat];
                for (let i = 0; i < table.length; i++) {
                    if (gross <= table[i][0]) return { rate: table[i][1], category: cat };
                }
                return { rate: 34, category: cat };
            },

            recalculate() {
                const gross = Number(this.monthlyGross || 0);
                const allowance = Number(this.monthlyAllowance || 0);
                const monthlyGrossTotal = gross + allowance;

                // Apply wage caps: BPJS Kesehatan capped at Rp 12,000,000 (Perpres 64/2020),
                // JP (pension) capped at batas atas upah set by Permenaker each year.
                // JHT has no upper cap.
                const bpjsBase = Math.min(monthlyGrossTotal, this.caps.bpjs);
                const pensionBase = Math.min(monthlyGrossTotal, this.caps.pension);

                // Employee deductions (subtracted from pay)
                const bpjsMonthly = bpjsBase * (this.rates.bpjs/100);
                const jhtMonthly = monthlyGrossTotal * (this.rates.jht/100);
                const pensionMonthly = pensionBase * (this.rates.pension/100);

                // Employer contributions included in taxable gross per PMK 168/2023:
                // BPJS Kesehatan employer, JKK, JKM.
                // JHT employer and JP employer are NOT included per common payroll practice.
                const selectedTier = this.jkkTiers.find(t => t.tier === Number(this.jkkTier)) || this.jkkTiers[0];
                const jkkRate = selectedTier.rate;
                const jkkMonthly = monthlyGrossTotal * (jkkRate/100);
                const jkmMonthly = monthlyGrossTotal * (this.rates.jkm/100);
                const bpjsEmployerMonthly = bpjsBase * (this.rates.bpjsEmployer/100);
                const jhtEmployerMonthly = monthlyGrossTotal * (this.rates.jhtEmployer/100);
                const pensionEmployerMonthly = pensionBase * (this.rates.pensionEmployer/100);
                const taxableGross = monthlyGrossTotal + jkkMonthly + jkmMonthly + bpjsEmployerMonthly;

                const annualGross = monthlyGrossTotal * 12;
                const annualBPJS = bpjsMonthly * 12;
                const annualJHT = jhtMonthly * 12;
                const annualPension = pensionMonthly * 12;

                const deps = Math.min(Math.max(Number(this.status.dependents || 0), 0), 3);
                const ptkpValue = 54000000 + (this.status.married ? 4500000 : 0) + (deps * 4500000);

                // PMK 168/2023: monthly PPh21 = taxable gross × TER rate.
                const ter = this.lookupTER(taxableGross);
                const monthlyTax = taxableGross * ter.rate / 100;
                // Take-home: basic gross minus employee deductions and tax (employer items net to zero)
                const takeHome = monthlyGrossTotal - bpjsMonthly - jhtMonthly - pensionMonthly - monthlyTax;

                // Exact Annual Calculation (Pasal 17) for December Reconciliation
                const annualGrossIncome = taxableGross * 12;
                // Biaya Jabatan max 500,000 / month = 6,000,000 / year
                const annualBiayaJabatan = Math.min(annualGrossIncome * 0.05, 6000000);
                const netAnnualIncome = annualGrossIncome - annualBiayaJabatan - annualJHT - annualPension;
                // Round PKP down to nearest 1000
                const pkp = Math.max(0, Math.floor((netAnnualIncome - ptkpValue) / 1000) * 1000);
                
                let exactAnnualTax = 0;
                let remainingPkp = pkp;
                
                if (remainingPkp > 0) {
                    const tier1 = Math.min(remainingPkp, 60000000);
                    exactAnnualTax += tier1 * 0.05;
                    remainingPkp -= tier1;
                }
                if (remainingPkp > 0) {
                    const tier2 = Math.min(remainingPkp, 190000000); // 250m - 60m
                    exactAnnualTax += tier2 * 0.15;
                    remainingPkp -= tier2;
                }
                if (remainingPkp > 0) {
                    const tier3 = Math.min(remainingPkp, 250000000); // 500m - 250m
                    exactAnnualTax += tier3 * 0.25;
                    remainingPkp -= tier3;
                }
                if (remainingPkp > 0) {
                    const tier4 = Math.min(remainingPkp, 4500000000); // 5b - 500m
                    exactAnnualTax += tier4 * 0.30;
                    remainingPkp -= tier4;
                }
                if (remainingPkp > 0) {
                    exactAnnualTax += remainingPkp * 0.35;
                }

                const taxPaidJanNov = monthlyTax * 11;
                // Dec tax can be higher or negative (refund)
                const decemberTax = exactAnnualTax - taxPaidJanNov;

                this.m = {
                    monthlyGross: monthlyGrossTotal,
                    taxableGross: taxableGross,
                    ptkpValue: ptkpValue,
                    monthlyBPJS: bpjsMonthly,
                    monthlyJHT: jhtMonthly,
                    monthlyPension: pensionMonthly,
                    monthlyTax: monthlyTax,
                    takeHome: takeHome,
                    annualGrossIncome: annualGrossIncome,
                    annualBiayaJabatan: annualBiayaJabatan,
                    annualContributions: annualJHT + annualPension,
                    exactAnnualTax: exactAnnualTax,
                    taxPaidJanNov: taxPaidJanNov,
                    decemberTax: decemberTax,
                    terCategory: ter.category,
                    terRate: ter.rate,
                    monthlyBPJSEmployer: bpjsEmployerMonthly,
                    jkkMonthly: jkkMonthly,
                    jkmMonthly: jkmMonthly,
                    jkkTierData: selectedTier
                };
            }
        }
    }
</script>
