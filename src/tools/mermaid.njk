<script>
    function mermaidTool() {
        return {
            diagramCode: `flowchart TD
    A[Idea] --> B{Pick Pattern}
    B -->|Simple| C[Flowchart]
    B -->|Timeline| D[Sequence Diagram]
    C --> E[Export Image]
    D --> E[Export Image]`,
            error: null,
            hasDiagram: false,
            panZoom: null,
            rawSvg: '',
            usedCheat: '',
            storageKey: 'mermaid-diagram-code',

            get highlightedDiagramCode() {
                if (!this.diagramCode) return '';

                return this.diagramCode
                    .split('\n')
                    .map((line) => `<div class="mermaid-editor-line">${this.highlightMermaidLine(line)}</div>`)
                    .join('');
            },

            cheatsheetCode: {
                flowchart: `flowchart TD
A[Start] --> B{Decision}
B -->|Yes| C[OK]
B -->|No| D[Retry]
C --> E([End])
D --> A`,
                sequence: `sequenceDiagram
  actor User
  participant App
  participant API
    participant Worker
    User->>App: Place order
    App->>API: POST /orders
    loop Retry up to 3x
        API->>Worker: Publish event
        Worker-->>API: Ack
    end
    alt Payment approved
        API-->>App: 201 Created
        App-->>User: Show success
    else Payment rejected
        API-->>App: 402 Payment Required
        App-->>User: Ask for another method
    end
    Note over App,API: Loop + alt for robust request handling`,
                class: `classDiagram
  class Animal {
    +String name
    +int age
    +eat() void
    +sleep() void
  }
  class Flyable {
    <<interface>>
    +fly() void
  }
  class Dog {
    +String breed
    +bark() void
  }
  class Bird {
    +String species
    +fly() void
  }
  Animal <|-- Dog : extends
  Animal <|-- Bird : extends
  Flyable <|.. Bird : implements
  Dog "1" --> "*" Owner : belongsTo`,
                state: `stateDiagram-v2
  [*] --> Idle
  Idle --> Loading : fetch()
  Loading --> Success : 200 OK
  Loading --> Error : timeout/4xx
  Error --> Idle : retry()
  Success --> Idle : reset()
  Success --> [*] : done`,
                gitgraph: `gitGraph
  commit id: "init"
  branch develop
  checkout develop
  branch feature/login
  checkout feature/login
  commit id: "add login"
  checkout develop
  merge feature/login
  branch release/1.0
  checkout release/1.0
  commit id: "bump v1.0"
  checkout main
  merge release/1.0 tag: "v1.0.0"
  checkout develop
  merge release/1.0
  checkout main
  branch hotfix/crash
  checkout hotfix/crash
  commit id: "fix crash"
  checkout main
  merge hotfix/crash tag: "v1.0.1"
  checkout develop
    merge hotfix/crash`,
                                pie: `pie title Engineering Time Allocation
    "Feature Delivery" : 45
    "Bug Fixing" : 20
    "Tech Debt" : 15
    "Code Review" : 10
    "Meetings" : 10`,
                                mindmap: `mindmap
    root((Product Platform))
        User Experience
            Web
            Mobile
            Accessibility
        Engineering
            Frontend
            Backend
            Platform
        Growth
            SEO
            Partnerships
            Community
        Observability
            Logs
            Metrics
            Traces`,
                                comboChart: `xychart-beta
  title "Traffic vs Conversion"
  x-axis [Jan, Feb, Mar, Apr, May, Jun]
  y-axis "Volume" 0 --> 220
  bar [120, 140, 165, 172, 185, 210]
  line [18, 21, 26, 29, 33, 38]`,
                                architectureSimple: `architecture-beta
  group devops(cloud)[GitHub]
  service repo(server)[Repository] in devops
  service cicd(server)[Actions CICD] in devops

  group cloudflare(cloud)[Cloudflare Stack]
  service proxy(cloud)[Proxy DNS] in cloudflare
  service worker(server)[Workers] in cloudflare
  service d1(database)[D1 Database] in cloudflare
  service r2(disk)[R2 Storage] in cloudflare
  service kv(disk)[KV] in cloudflare
  service logs(disk)[Logs Analytics] in cloudflare

  service client(internet)[Client]

  client:R --> L:proxy
  repo:R --> L:cicd
  cicd:B --> T:worker
  proxy:R --> L:worker
  worker:R --> L:d1
  worker:R --> L:r2
  worker:R --> L:kv
    worker:B --> T:logs`,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                flutterBlock: `block
    columns 3
    a:3
    block:group1:2
        columns 2
        h i
        j k
    end
    g
    block:group2:3
        l m n o p q r
    end`,

                                                                dbDiagram: `erDiagram
    USERS ||--o{ SESSIONS : has
    USERS ||--o{ ORDERS : places
    ORDERS ||--|{ ORDER_ITEMS : contains
    PRODUCTS ||--o{ ORDER_ITEMS : referenced_by
    ORDERS }o--|| ADDRESSES : ships_to
    USERS ||--o{ ADDRESSES : owns

    USERS {
        uuid id PK
        string email
        string full_name
        datetime created_at
    }

    ORDERS {
        uuid id PK
        uuid user_id FK
        string status
        decimal total_amount
        datetime created_at
    }

    PRODUCTS {
        uuid id PK
        string name
        decimal price
        int stock
    }`,
                                treeview: `treeView-beta
    "Company"
        "Engineering"
            "Backend Team"
                "Platform Squad"
                "Payments Squad"
            "Frontend Team"
                "Web App Squad"
            "Mobile Team"
        "Product"
        "Operations"
            "SRE"
            "Customer Support"`
            },

            init() {
                mermaid.initialize({
                    startOnLoad: false,
                    securityLevel: 'loose',
                    theme: 'default'
                });

                try {
                    const savedCode = localStorage.getItem(this.storageKey);
                    if (savedCode !== null) {
                        this.diagramCode = savedCode;
                    }

                    this.$watch('diagramCode', () => {
                        this.saveToStorage();
                    });
                } catch (_) {
                    // Ignore storage errors in restricted contexts.
                }

                this.$nextTick(() => {
                    this.renderDiagram();
                });
            },

            saveToStorage() {
                try {
                    localStorage.setItem(this.storageKey, this.diagramCode);
                } catch (_) {
                    // Ignore storage errors in restricted contexts.
                }
            },

            syncEditorScroll() {
                if (!this.$refs.codeInput || !this.$refs.highlightLayer) return;
                this.$refs.highlightLayer.scrollTop = this.$refs.codeInput.scrollTop;
                this.$refs.highlightLayer.scrollLeft = this.$refs.codeInput.scrollLeft;
            },

            escapeHtml(text) {
                return text
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;');
            },

            highlightMermaidLine(line) {
                if (!line) return '&nbsp;';

                const raw = line;
                const trimmed = raw.trim();

                if (trimmed.startsWith('%%')) {
                    return `<span class="syntax-mermaid-comment">${this.escapeHtml(raw)}</span>`;
                }

                let escaped = this.escapeHtml(raw);

                // Strings wrapped in quotes.
                escaped = escaped.replace(/(&quot;[^&]*?&quot;)/g, '<span class="syntax-mermaid-string">$1</span>');

                // Diagram and control keywords.
                escaped = escaped.replace(/\b(flowchart|graph|sequenceDiagram|classDiagram|stateDiagram-v2|stateDiagram|erDiagram|journey|gantt|pie|mindmap|timeline|gitGraph|xychart-beta|architecture-beta|block|treeView-beta|subgraph|classDef|class|style|linkStyle|click|title|participant|actor|loop|alt|else|opt|par|and|end|note|section|accTitle|accDescr|direction|TB|TD|BT|LR|RL)\b/g, '<span class="syntax-mermaid-keyword">$1</span>');

                // Arrows and relationships.
                escaped = escaped.replace(/(---|-->|==>|-\.->|\.->|->>|-->>|<->|<-->|<-|->|\|\||\|\{)/g, '<span class="syntax-mermaid-arrow">$1</span>');

                // Node labels and edge labels.
                escaped = escaped.replace(/(\[[^\]]+\]|\{[^}]+\}|\([^)]*\)|\(\([^)]*\)\)|\|[^|]+\|)/g, '<span class="syntax-mermaid-label">$1</span>');

                // Number values.
                escaped = escaped.replace(/\b(\d+(?:\.\d+)?)\b/g, '<span class="syntax-mermaid-number">$1</span>');

                // Punctuation connectors.
                escaped = escaped.replace(/(:|;|,)/g, '<span class="syntax-mermaid-connector">$1</span>');

                return escaped;
            },

            clearCode() {
                this.diagramCode = '';
                this.error = null;
                this.hasDiagram = false;
                this.rawSvg = '';
                if (this.panZoom) {
                    this.panZoom.destroy();
                    this.panZoom = null;
                }
                this.$refs.diagramViewport.innerHTML = '';
            },

            resetSample() {
                this.diagramCode = `flowchart TD
    A[Idea] --> B{Pick Pattern}
    B -->|Simple| C[Flowchart]
    B -->|Timeline| D[Sequence Diagram]
    C --> E[Export Image]
    D --> E[Export Image]`;
                this.renderDiagram();
            },

            async renderDiagram() {
                this.error = null;

                if (!this.diagramCode.trim()) {
                    this.clearCode();
                    return;
                }

                try {
                    const diagramId = `mermaid-${Date.now()}`;
                    const rendered = await mermaid.render(diagramId, this.diagramCode);

                    if (this.panZoom) {
                        this.panZoom.destroy();
                        this.panZoom = null;
                    }

                    this.rawSvg = rendered.svg;
                    this.$refs.diagramViewport.innerHTML = rendered.svg;
                    this.hasDiagram = true;

                    this.$nextTick(() => {
                        this.initPanZoom();
                    });
                } catch (e) {
                    this.hasDiagram = false;
                    this.error = e && e.message ? e.message : 'Failed to render diagram.';
                    this.$refs.diagramViewport.innerHTML = '';
                }
            },

            initPanZoom() {
                const svg = this.$refs.diagramViewport.querySelector('svg');
                if (!svg) return;

                this.normalizeSvgBounds(svg);
                svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
                svg.style.width = '100%';
                svg.style.height = '100%';
                svg.style.display = 'block';
                svg.style.maxWidth = 'none';
                svg.style.overflow = 'visible';

                this.panZoom = svgPanZoom(svg, {
                    zoomEnabled: true,
                    controlIconsEnabled: false,
                    fit: true,
                    center: true,
                    minZoom: 0.3,
                    maxZoom: 8,
                    mouseWheelZoomEnabled: true,
                    dblClickZoomEnabled: true,
                    panEnabled: true
                });

                this.panZoom.resize();
                this.panZoom.updateBBox();
                this.panZoom.fit();
                this.panZoom.center();

                // Re-fit when user drags the canvas container to a new height.
                if (this._canvasObserver) this._canvasObserver.disconnect();
                this._canvasObserver = new ResizeObserver(() => {
                    if (this.panZoom) {
                        this.panZoom.resize();
                        this.panZoom.fit();
                        this.panZoom.center();
                    }
                });
                this._canvasObserver.observe(this.$refs.diagramViewport.parentElement);
            },

            normalizeSvgBounds(svg) {
                // Mermaid can place labels/strokes near edges; pad the viewBox to avoid clipping while zooming.
                const viewportNode = svg.querySelector('.svg-pan-zoom_viewport') || svg.querySelector('g');
                if (!viewportNode || typeof viewportNode.getBBox !== 'function') return;

                try {
                    const bbox = viewportNode.getBBox();
                    if (!bbox || bbox.width <= 0 || bbox.height <= 0) return;

                    const padding = 24;
                    const minX = bbox.x - padding;
                    const minY = bbox.y - padding;
                    const width = bbox.width + (padding * 2);
                    const height = bbox.height + (padding * 2);

                    svg.setAttribute('viewBox', `${minX} ${minY} ${width} ${height}`);
                    svg.setAttribute('width', String(width));
                    svg.setAttribute('height', String(height));
                } catch (_) {
                    // Ignore bbox errors for unsupported diagram nodes.
                }
            },

            zoomIn() {
                if (!this.panZoom) return;
                this.panZoom.zoomIn();
            },

            zoomOut() {
                if (!this.panZoom) return;
                this.panZoom.zoomOut();
            },

            resetView() {
                if (!this.panZoom) return;
                this.panZoom.resetZoom();
                this.panZoom.fit();
                this.panZoom.center();
            },

            downloadSvg() {
                if (!this.rawSvg) return;

                const blob = new Blob([this.rawSvg], { type: 'image/svg+xml;charset=utf-8' });
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = 'mermaid-diagram.svg';
                link.style.display = 'none';
                document.body.appendChild(link);
                link.click();
                setTimeout(() => { document.body.removeChild(link); URL.revokeObjectURL(url); }, 300);
            },

            downloadPng() {
                if (!this.rawSvg) return;

                // Parse viewBox from the clean raw SVG to get true diagram dimensions.
                const parser = new DOMParser();
                const svgDoc = parser.parseFromString(this.rawSvg, 'image/svg+xml');
                const exportSvg = svgDoc.querySelector('svg');
                const viewBox = exportSvg && exportSvg.viewBox && exportSvg.viewBox.baseVal ? exportSvg.viewBox.baseVal : null;
                const width = Math.max(1, Math.round(viewBox && viewBox.width > 0 ? viewBox.width : 1200));
                const height = Math.max(1, Math.round(viewBox && viewBox.height > 0 ? viewBox.height : 800));
                const scale = 2;

                // Use a data URI instead of a Blob URL to avoid tainted-canvas SecurityError.
                const dataUri = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(this.rawSvg)));

                const image = new Image();
                image.onload = () => {
                    const canvas = document.createElement('canvas');
                    canvas.width = width * scale;
                    canvas.height = height * scale;

                    const ctx = canvas.getContext('2d');
                    if (!ctx) return;

                    ctx.fillStyle = '#ffffff';
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                    ctx.scale(scale, scale);
                    ctx.drawImage(image, 0, 0, width, height);

                    canvas.toBlob((blob) => {
                        if (!blob) return;
                        const pngUrl = URL.createObjectURL(blob);
                        const link = document.createElement('a');
                        link.href = pngUrl;
                        link.download = 'mermaid-diagram.png';
                        link.style.display = 'none';
                        document.body.appendChild(link);
                        link.click();
                        setTimeout(() => { document.body.removeChild(link); URL.revokeObjectURL(pngUrl); }, 300);
                    }, 'image/png');
                };

                image.onerror = () => {
                    this.error = 'Failed to export PNG. Try downloading SVG instead.';
                };

                image.src = dataUri;
            },

            useCheat(key) {
                const content = this.cheatsheetCode[key];
                if (!content) return;

                this.diagramCode = content;
                this.renderDiagram();
                this.usedCheat = key;
                setTimeout(() => {
                    if (this.usedCheat === key) this.usedCheat = '';
                }, 1500);
            },

            // getExportSvgSource removed — export now uses this.rawSvg directly.
        }
    }
</script>
